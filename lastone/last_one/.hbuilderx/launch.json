{
    // launch.json 設定了啟動調試時相關設定，configurations下節點名稱可為 app-plus/h5/mp-weixin/mp-baidu/mp-alipay/mp-qq/mp-toutiao/mp-360/
    // launchtype項可設定值為local或remote, local代表前端連本地雲端函式，remote代表前端連雲端雲端函式
    "version" : "0.0",
    "configurations" : [
        {
            "app-plus" : {
                "launchtype" : "remote"
            },
            "default" : {
                "launchtype" : "local"
            },
            "h5" : {
                "launchtype" : "local"
            },
            "provider" : "tcb",
            "type" : "uniCloud"
        }
    ]
}
